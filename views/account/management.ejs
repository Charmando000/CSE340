<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title><%= title %></title>
        <link rel="stylesheet" href="/css/styles.css">
    </head>
    <body>

        <h1>Account Management</h1>

        <!-- Mensaje flash -->
        <% if (notice) { %>
            <p><%= notice %></p>
        <% } %>

        <!-- Errores -->
        <% if (errors) { %>
            <ul>
                <% errors.array().forEach(error => { %>
                    <li><%= error.msg %></li>
                <% }) %>
            </ul>
        <% } %>

        <% if (accountData) { %>
            <% if (accountData.account_type === "Client") { %>
                <h2>Welcome <%= accountData.account_firstname %></h2>
                <p><a href="/account/update/<%= accountData.account_id %>">Update Account Information</a></p>
            <% } else if (accountData.account_type === "Employee" || accountData.account_type === "Admin") { %>
                <h2>Welcome <%= accountData.account_firstname %></h2>
                <p><a href="/account/update/<%= accountData.account_id %>">Update Account Information</a></p>
                <h3>Inventory Management</h3>
                <p><a href="/inv/">Manage Inventory</a></p>
            <% } else { %>
                <h2>Welcome <%= accountData.account_firstname %></h2>
                <p><a href="/account/update/<%= accountData.account_id %>">Update Account Information</a></p>
            <% } %>
        <% } else { %>
            <p>Unable to load your account information.</p>
        <% } %>

    </body>
</html>