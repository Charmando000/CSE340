<!DOCTYPE html>
<html lang="en-US">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css">
</head>

<body>

  <% if (errors) { %>
    <ul class="notice">
      <% errors.array().forEach(error => { %>
        <li><%= error.msg %></li>
      <% }) %>
    </ul>
  <% } %>

  <%- messages() %>

  <h1><%= title %></h1>

  <form action="/account/update" method="post">
    <input type="hidden" name="account_id" value="<%= accountData ? accountData.account_id : locals.account_id %>">

    <label for="accountFirstname">First Name:</label>
    <input type="text" id="accountFirstname" name="account_firstname" required value="<%= locals.account_firstname || (accountData && accountData.account_firstname) || '' %>">

    <label for="accountLastname">Last Name:</label>
    <input type="text" id="accountLastname" name="account_lastname" required value="<%= locals.account_lastname || (accountData && accountData.account_lastname) || '' %>">

    <label for="accountEmail">Email:</label>
    <input type="email" id="accountEmail" name="account_email" required placeholder="Enter a valid email address" value="<%= locals.account_email || (accountData && accountData.account_email) || '' %>">

    <button type="submit">Update Account</button>
  </form>

  <section>
    <h2>Change Password</h2>
    <p>Enter a new password to replace your current password. Passwords must be at least 12 characters long, include 1 capital letter, 1 number, and 1 special character.</p>

    <form action="/account/update-password" method="post">
      <input type="hidden" name="account_id" value="<%= accountData ? accountData.account_id : locals.account_id %>">

      <label for="password">New Password:</label>
      <input type="password" id="password" name="account_password" required pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!=.*\s).{12,}$">

      <button type="submit">Change Password</button>
    </form>
  </section>

</body>
</html>
